---
layout: base.njk
title: Blog & Articles
permalink: /blog/
---
<style>
.blog-hero{background:var(--blue);padding:8rem 8vw 5rem;margin-top:72px;position:relative;overflow:hidden}
.blog-hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,199,38,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,199,38,.05) 1px,transparent 1px);background-size:60px 60px}
.blog-hero-inner{position:relative;z-index:1}
.eyebrow{font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,199,38,.85);font-weight:700;margin-bottom:.9rem;display:flex;align-items:center;gap:.6rem}
.eyebrow::before{content:'';width:24px;height:2px;background:var(--gold)}
.blog-hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:700;color:var(--white);line-height:1.1;margin-bottom:1rem}
.blog-hero h1 em{font-style:italic;color:var(--gold);font-weight:400}
.blog-hero p{font-size:.95rem;color:rgba(255,255,255,.65);max-width:520px;line-height:1.75}
.filters-bar{padding:2rem 8vw;background:var(--off-white);border-bottom:1px solid var(--line);display:flex;gap:.7rem;flex-wrap:wrap;align-items:center}
.filter-label{font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;font-weight:700;color:var(--muted);margin-right:.3rem}
.filter-btn{background:var(--white);color:var(--muted);border:1px solid var(--line);padding:.4rem 1rem;border-radius:100px;font-size:.76rem;font-weight:500;cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif}
.filter-btn:hover,.filter-btn.active{background:var(--blue);color:var(--white);border-color:var(--blue)}
.posts-section{padding:4rem 8vw 6rem}
.posts-count{font-size:.82rem;color:var(--muted);margin-bottom:2rem}
.posts-count span{font-weight:600;color:var(--blue)}
.posts-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem}
.post-card{background:var(--off-white);border-radius:4px;overflow:hidden;border:1px solid var(--line);transition:box-shadow .25s,transform .25s;display:flex;flex-direction:column;text-decoration:none;color:inherit}
.post-card:hover{box-shadow:0 12px 40px rgba(0,38,127,.1);transform:translateY(-4px)}
.post-img{height:180px;display:flex;align-items:center;justify-content:center}
.post-img-icon{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center}
.post-img-icon svg{stroke:rgba(255,255,255,.8)}
.post-body{padding:1.8rem;display:flex;flex-direction:column;flex:1}
.post-tag{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-dark);font-weight:700;margin-bottom:.5rem}
.post-title{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--blue);line-height:1.3;margin-bottom:.7rem}
.post-excerpt{font-size:.82rem;line-height:1.65;color:var(--muted);flex:1;margin-bottom:1rem}
.post-meta{font-size:.72rem;color:rgba(86,96,128,.6);margin-bottom:.8rem}
.post-link{display:inline-flex;align-items:center;gap:.4rem;font-size:.76rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--blue);margin-top:auto}
.no-posts{text-align:center;padding:4rem 2rem;color:var(--muted);grid-column:1/-1}
.no-posts h3{font-family:'Playfair Display',serif;color:var(--blue);margin-bottom:.5rem;font-size:1.5rem}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.post-card{animation:fadeUp .5s both}
@media(max-width:960px){.posts-grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.posts-grid{grid-template-columns:1fr}.posts-section{padding:3rem 5vw}.blog-hero{padding:6rem 5vw 3rem}.filters-bar{padding:1.5rem 5vw}}
</style>

<div class="blog-hero">
  <div class="blog-hero-inner">
    <p class="eyebrow">Insights & Perspectives</p>
    <h1>Blog & <em>Articles</em></h1>
    <p>Expert commentary on finance, tax, payroll, and business strategy from the DavisSon & Associates team.</p>
  </div>
</div>

<div class="filters-bar">
  <span class="filter-label">Filter:</span>
  <button class="filter-btn active" data-filter="all">All</button>
  <button class="filter-btn" data-filter="Business Advisory">Advisory</button>
  <button class="filter-btn" data-filter="Tax Services">Tax</button>
  <button class="filter-btn" data-filter="Payroll Services">Payroll</button>
  <button class="filter-btn" data-filter="Accounting Software">Software</button>
  <button class="filter-btn" data-filter="Bookkeeping & Accounting">Bookkeeping</button>
  <button class="filter-btn" data-filter="Compliance Services">Compliance</button>
  <button class="filter-btn" data-filter="Financial Planning">Planning</button>
  <button class="filter-btn" data-filter="Technology">Technology</button>
</div>

<section class="posts-section">
  <p class="posts-count" id="posts-count">Showing <span id="count-num">{{ collections.posts | length }}</span> articles</p>
  <div class="posts-grid" id="posts-grid">
    {% for post in collections.posts | reverse %}
    <a class="post-card" href="{{ post.url }}" data-category="{{ post.data.category }}" style="animation-delay: {{ loop.index0 * 0.08 }}s">
      <div class="post-img" style="background:{% if post.data.category == 'Business Advisory' %}linear-gradient(135deg,#001A5C,#00267F){% elif post.data.category == 'Tax Services' %}linear-gradient(135deg,#00267F,#0033A8){% elif post.data.category == 'Accounting Software' %}linear-gradient(135deg,#D4A200,#FFC726){% elif post.data.category == 'Payroll Services' %}linear-gradient(135deg,#001A5C,#003399){% elif post.data.category == 'Technology' %}linear-gradient(135deg,#D4A200,#FFC726){% else %}linear-gradient(135deg,#001A5C,#00267F){% endif %}">
        <div class="post-img-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
      </div>
      <div class="post-body">
        <p class="post-tag">{{ post.data.category }}</p>
        <h2 class="post-title">{{ post.data.title }}</h2>
        <p class="post-excerpt">{{ post.data.excerpt }}</p>
        <p class="post-meta">{{ post.data.author }} · {{ post.data.date | dateDisplay }}</p>
        <span class="post-link">Read Article →</span>
      </div>
    </a>
    {% else %}
    <div class="no-posts">
      <h3>No articles yet</h3>
      <p>Check back soon — new articles are published regularly.</p>
    </div>
    {% endfor %}
  </div>
</section>

<script>
const cards = document.querySelectorAll('.post-card[data-category]');
const countEl = document.getElementById('count-num');
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    let visible = 0;
    cards.forEach((card, i) => {
      const show = filter === 'all' || card.dataset.category === filter;
      card.style.display = show ? 'flex' : 'none';
      if(show){ card.style.animationDelay = (visible * 0.08) + 's'; visible++; }
    });
    countEl.textContent = visible;
  });
});
</script>
