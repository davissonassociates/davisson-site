<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ title }} — DavisSon & Associates Inc.</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#00267F;--blue-dark:#001A5C;--blue-mid:#0033A8;--blue-light:#e8eef8;
  --gold:#FFC726;--gold-dark:#D4A200;
  --black:#0D0D0D;--off-white:#F7F8FC;--white:#FFFFFF;--muted:#556080;
  --line:rgba(0,38,127,0.1);
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--black);overflow-x:hidden}
#nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;background:rgba(255,255,255,0.97);box-shadow:0 1px 0 var(--line),0 4px 30px rgba(0,38,127,0.08)}
.nav-logo{text-decoration:none;display:flex;flex-direction:column;gap:1px}
.nav-logo-main{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--blue)}
.nav-logo-sub{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold-dark);font-weight:500}
.nav-menu{display:flex;align-items:center;gap:2.2rem}
.nav-menu a{font-size:.76rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s;position:relative}
.nav-menu a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .25s}
.nav-menu a:hover{color:var(--blue)}
.nav-menu a:hover::after{transform:scaleX(1)}
.nav-menu a.active{color:var(--blue)}
.nav-menu a.active::after{transform:scaleX(1)}
.nav-cta{background:var(--gold);color:var(--blue-dark);padding:.55rem 1.4rem;font-size:.76rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background .2s}
.nav-cta:hover{background:#FFCE3D}
.ham{display:none;background:none;border:none;cursor:pointer;padding:4px;flex-direction:column;gap:5px}
.ham span{display:block;width:22px;height:2px;background:var(--blue)}
.mobile-nav{display:none;position:fixed;top:72px;left:0;right:0;z-index:999;background:var(--white);flex-direction:column;border-bottom:3px solid var(--blue);box-shadow:0 8px 40px rgba(0,0,0,.12)}
.mobile-nav.open{display:flex}
.mobile-nav a{padding:1rem 5vw;font-size:.9rem;font-weight:500;color:var(--blue);text-decoration:none;border-bottom:1px solid var(--line);letter-spacing:.04em;text-transform:uppercase}
#back-top{position:fixed;bottom:2rem;right:2rem;z-index:900;width:46px;height:46px;border-radius:50%;background:var(--blue);color:var(--white);border:2px solid var(--gold);display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 20px rgba(0,38,127,.3);opacity:0;visibility:hidden;pointer-events:none;transition:opacity .3s,visibility .3s,transform .2s,background .2s;transform:translateY(12px)}
#back-top.show{opacity:1;visibility:visible;pointer-events:auto;transform:translateY(0)}
#back-top:hover{background:var(--gold);color:var(--blue-dark);transform:translateY(-3px)}
footer{background:var(--black);padding:4rem 8vw 2rem}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;padding-bottom:3rem;border-bottom:1px solid rgba(255,255,255,.08)}
.foot-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--white);margin-bottom:.3rem}
.foot-logo-sub{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem}
.foot-desc{font-size:.82rem;color:rgba(255,255,255,.35);line-height:1.75;max-width:260px}
.foot-col h4{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.3);font-weight:700;margin-bottom:1.2rem}
.foot-col ul{list-style:none;display:flex;flex-direction:column;gap:.65rem}
.foot-col a{font-size:.82rem;color:rgba(255,255,255,.5);text-decoration:none;transition:color .2s}
.foot-col a:hover{color:var(--gold)}
.footer-bot{padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.foot-copy{font-size:.74rem;color:rgba(255,255,255,.22)}
.foot-gold-line{width:40px;height:3px;background:var(--gold);border-radius:2px}
@media(max-width:960px){.nav-menu,.nav-cta{display:none}.ham{display:flex}.footer-grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.footer-grid{grid-template-columns:1fr}}
</style>
</head>
<body>
<nav id="nav">
  <a href="/" class="nav-logo">
    <span class="nav-logo-main">DavisSon & Associates</span>
    <span class="nav-logo-sub">Chartered Certified Accountants</span>
  </a>
  <div class="nav-menu">
    <a href="/#about">About</a>
    <a href="/#services">Services</a>
    <a href="/#payroll">Payroll</a>
    <a href="/#software">Software</a>
    <a href="/#team">Team</a>
    <a href="/#why">Why Us</a>
    <a href="/blog/" class="{% if 'blog' in page.url %}active{% endif %}">Blog</a>
    <a href="/#contact">Contact</a>
  </div>
  <a href="/#contact" class="nav-cta">Get in Touch</a>
  <button class="ham" id="ham" aria-label="Open menu"><span></span><span></span><span></span></button>
</nav>
<div class="mobile-nav" id="mob-nav">
  <a href="/#about" onclick="closeMob()">About</a>
  <a href="/#services" onclick="closeMob()">Services</a>
  <a href="/#payroll" onclick="closeMob()">Payroll</a>
  <a href="/#software" onclick="closeMob()">Software</a>
  <a href="/#team" onclick="closeMob()">Team</a>
  <a href="/#why" onclick="closeMob()">Why Us</a>
  <a href="/blog/" onclick="closeMob()">Blog</a>
  <a href="/#contact" onclick="closeMob()">Contact</a>
</div>

{{ content | safe }}

