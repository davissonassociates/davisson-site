<script>
window.addEventListener('scroll',()=>{
  const s=scrollY>40;
  document.getElementById('nav').classList.toggle('scrolled',s);
  document.getElementById('back-top').classList.toggle('show',scrollY>400);
},{passive:true});
const ham=document.getElementById('ham');
const mob=document.getElementById('mob-nav');
ham.addEventListener('click',()=>mob.classList.toggle('open'));
function closeMob(){mob.classList.remove('open')}
const io=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}});
},{threshold:0.1,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
function submitForm(){
  alert('Thank you for your message!\n\nWe\'ll be in touch within one business day.\n\nFor urgent matters:\n(246) 851-3750\noffice@davissonassociates.com');
}
</script>
