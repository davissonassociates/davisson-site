<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DavisSon & Associates Inc. — Comprehensive Financial Services, Barbados</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#00267F;--blue-dark:#001A5C;--blue-mid:#0033A8;--blue-light:#e8eef8;
  --gold:#FFC726;--gold-dark:#D4A200;
  --black:#0D0D0D;--off-white:#F7F8FC;--white:#FFFFFF;--muted:#556080;
  --line:rgba(0,38,127,0.1);
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--black);overflow-x:hidden}

/* ANIMATIONS */
@keyframes tridentFloat{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-18px) rotate(-3deg)}}
@keyframes goldPulse{0%,100%{opacity:0.08}50%{opacity:0.18}}
@keyframes marqueeScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

.reveal{opacity:0;transform:translateY(32px);transition:opacity 0.7s cubic-bezier(.4,0,.2,1),transform 0.7s cubic-bezier(.4,0,.2,1)}
.reveal.from-left{transform:translateX(-32px)}
.reveal.from-right{transform:translateX(32px)}
.reveal.scale{transform:scale(0.94)}
.reveal.visible{opacity:1;transform:none}
.reveal-delay-1{transition-delay:0.1s}.reveal-delay-2{transition-delay:0.2s}
.reveal-delay-3{transition-delay:0.3s}.reveal-delay-4{transition-delay:0.4s}
.reveal-delay-5{transition-delay:0.5s}.reveal-delay-6{transition-delay:0.6s}
@media(prefers-reduced-motion:reduce){
  .reveal,.reveal.from-left,.reveal.from-right,.reveal.scale{opacity:1;transform:none;transition:none}
  .trident{animation:none!important}
}

/* NAV */
#nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 5vw;background:transparent;transition:background .4s,box-shadow .4s;
}
#nav.scrolled{background:rgba(255,255,255,0.97);box-shadow:0 1px 0 var(--line),0 4px 30px rgba(0,38,127,0.08)}
.nav-logo{text-decoration:none;display:flex;flex-direction:column;gap:1px}
.nav-logo-main{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--white);letter-spacing:.01em;transition:color .3s}
.nav-logo-sub{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:500;transition:color .3s}
#nav.scrolled .nav-logo-main{color:var(--blue)}
#nav.scrolled .nav-logo-sub{color:var(--gold-dark)}
.nav-menu{display:flex;align-items:center;gap:2.2rem}
.nav-menu a{
  font-size:.76rem;font-weight:500;letter-spacing:.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.8);text-decoration:none;transition:color .2s;position:relative;
}
.nav-menu a::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .25s;
}
.nav-menu a:hover{color:var(--white)}
.nav-menu a:hover::after{transform:scaleX(1)}
#nav.scrolled .nav-menu a{color:var(--muted)}
#nav.scrolled .nav-menu a:hover{color:var(--blue)}
.nav-cta{
  background:var(--gold);color:var(--blue-dark);
  padding:.55rem 1.4rem;font-size:.76rem;font-weight:600;
  letter-spacing:.07em;text-transform:uppercase;text-decoration:none;
  border-radius:2px;transition:background .2s,transform .15s;
}
.nav-cta:hover{background:#FFCE3D;transform:translateY(-1px)}
.ham{display:none;background:none;border:none;cursor:pointer;padding:4px;flex-direction:column;gap:5px}
.ham span{display:block;width:22px;height:2px;background:var(--white);transition:.3s}
#nav.scrolled .ham span{background:var(--blue)}

/* MOBILE NAV */
.mobile-nav{
  display:none;position:fixed;top:72px;left:0;right:0;z-index:999;
  background:var(--white);flex-direction:column;gap:0;
  border-bottom:3px solid var(--blue);box-shadow:0 8px 40px rgba(0,0,0,.12);
}
.mobile-nav.open{display:flex}
.mobile-nav a{
  padding:1rem 5vw;font-size:.9rem;font-weight:500;color:var(--blue);
  text-decoration:none;border-bottom:1px solid var(--line);
  letter-spacing:.04em;text-transform:uppercase;
}
.mobile-nav a:last-child{border-bottom:none}

/* BACK TO TOP */
#back-top{
  position:fixed;bottom:2rem;right:2rem;z-index:900;
  width:46px;height:46px;border-radius:50%;
  background:var(--blue);color:var(--white);border:2px solid var(--gold);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;box-shadow:0 4px 20px rgba(0,38,127,.3);
  opacity:0;visibility:hidden;pointer-events:none;
  transition:opacity .3s,visibility .3s,transform .2s,background .2s;
  transform:translateY(12px);
}
#back-top.show{opacity:1;visibility:visible;pointer-events:auto;transform:translateY(0)}
#back-top:hover{background:var(--gold);color:var(--blue-dark);transform:translateY(-3px)}

/* HERO */
#hero{
  min-height:100vh;background:var(--blue);position:relative;overflow:hidden;
  display:grid;grid-template-columns:1fr 1fr;align-items:center;
  padding:0 8vw;padding-top:72px;
}
.hero-bg-grid{
  position:absolute;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(255,199,38,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,199,38,.05) 1px,transparent 1px);
  background-size:60px 60px;
}
.hero-bg-glow{
  position:absolute;top:-200px;right:-200px;width:700px;height:700px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,199,38,.15) 0%,transparent 70%);
  animation:goldPulse 6s ease-in-out infinite;
}
.hero-bg-glow2{
  position:absolute;bottom:-300px;left:-100px;width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,51,168,.4) 0%,transparent 70%);
}
.hero-left-col{position:relative;z-index:2;padding-right:4vw}
.hero-badge{
  display:inline-flex;align-items:center;gap:.6rem;
  background:rgba(255,199,38,.12);border:1px solid rgba(255,199,38,.3);
  padding:.4rem 1rem;border-radius:2px;
  font-size:.7rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:2rem;
}
.hero-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold)}
.hero-h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,5vw,5.2rem);font-weight:900;line-height:1.02;color:var(--white);margin-bottom:1.5rem}
.hero-h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:1rem;line-height:1.75;color:rgba(255,255,255,.68);max-width:460px;margin-bottom:2.5rem}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.btn-gold{
  background:var(--gold);color:var(--blue-dark);padding:.85rem 2.2rem;font-size:.8rem;
  font-weight:700;letter-spacing:.07em;text-transform:uppercase;text-decoration:none;
  border-radius:2px;transition:background .2s,transform .15s;display:inline-block;
  box-shadow:0 4px 20px rgba(255,199,38,.35);
}
.btn-gold:hover{background:#FFCE3D;transform:translateY(-2px)}
.btn-ghost{
  background:transparent;color:var(--white);padding:.85rem 2.2rem;font-size:.8rem;
  font-weight:500;letter-spacing:.07em;text-transform:uppercase;text-decoration:none;
  border:1px solid rgba(255,255,255,.3);border-radius:2px;transition:border-color .2s,background .2s;display:inline-block;
}
.btn-ghost:hover{border-color:var(--white);background:rgba(255,255,255,.06)}
.hero-right-col{position:relative;z-index:2;display:flex;flex-direction:column;align-items:flex-start}
.trident{width:100%;max-width:380px;animation:tridentFloat 5s ease-in-out infinite}

/* TICKER */
.ticker{background:var(--gold);padding:.8rem 0;overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-flex;gap:0;animation:marqueeScroll 34s linear infinite}
.ticker-item{
  display:inline-flex;align-items:center;gap:.8rem;padding:0 2.5rem;
  font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--blue-dark);
}
.ticker-item::after{content:'◆';font-size:.45rem;color:var(--blue);opacity:.5}

/* SHARED SECTION */
section{padding:7rem 8vw}
.eyebrow{
  font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;
  color:var(--gold-dark);font-weight:700;margin-bottom:.9rem;
  display:flex;align-items:center;gap:.6rem;
}
.eyebrow::before{content:'';width:24px;height:2px;background:var(--gold)}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,3.2vw,3rem);font-weight:700;color:var(--blue);line-height:1.15;margin-bottom:1.2rem}
.section-title em{font-style:italic;font-weight:400}
.section-body{font-size:.95rem;line-height:1.8;color:var(--muted);max-width:560px}

/* SVG ICON UTIL */
.ico{display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* ABOUT */
#about{background:var(--off-white);display:grid;grid-template-columns:1fr 1fr;gap:6vw;align-items:center}
.about-stat-card{background:var(--blue);border-radius:4px;padding:2.8rem;margin-bottom:1.5rem;position:relative;overflow:hidden}
.about-stat-card::before{content:'';position:absolute;top:-80px;right:-80px;width:250px;height:250px;border-radius:50%;background:rgba(255,199,38,.07)}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem}
.stat-num{font-family:'Playfair Display',serif;font-size:2.6rem;font-weight:700;color:var(--gold);line-height:1}
.stat-label{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-top:.3rem}
.about-quote{background:var(--gold);padding:2rem 2.2rem;border-radius:2px;font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:400;font-style:italic;color:var(--blue-dark);line-height:1.6}
.about-quote cite{display:block;margin-top:.8rem;font-family:'DM Sans',sans-serif;font-style:normal;font-size:.75rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--blue)}
.about-text .section-body{max-width:none}
.about-pills{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:2rem}
.pill{background:var(--blue-light);color:var(--blue);padding:.4rem 1rem;border-radius:100px;font-size:.78rem;font-weight:500}

/* SERVICES */
#services{background:var(--white)}
.services-head{display:grid;grid-template-columns:1fr 1fr;gap:4rem;margin-bottom:4rem;align-items:end}
.services-intro .section-body{max-width:none}
.services-intro a{display:inline-flex;align-items:center;gap:.5rem;margin-top:1.5rem;font-size:.82rem;font-weight:600;color:var(--blue);text-decoration:none;letter-spacing:.04em;text-transform:uppercase}
.services-intro a svg{transition:transform .2s}
.services-intro a:hover svg{transform:translateX(4px)}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line)}
.svc-card{background:var(--white);padding:2.2rem 2rem;transition:background .25s,transform .25s;cursor:default;position:relative;overflow:hidden}
.svc-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.svc-card:hover{background:var(--blue);transform:translateY(-4px);z-index:2;box-shadow:0 12px 40px rgba(0,38,127,.2)}
.svc-card:hover::after{transform:scaleX(1)}
.svc-card:hover .svc-title,.svc-card:hover .svc-body{color:var(--white)}
.svc-card:hover .svc-num{color:rgba(255,255,255,.2)}
.svc-card:hover .svc-icon-wrap{background:rgba(255,199,38,.18)}
.svc-card:hover .svc-icon-wrap svg{stroke:var(--gold)}
.svc-num{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;color:rgba(0,38,127,.06);line-height:1;margin-bottom:.8rem;transition:color .25s}
.svc-icon-wrap{width:44px;height:44px;border-radius:50%;background:var(--blue-light);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;transition:background .25s}
.svc-icon-wrap svg{stroke:var(--blue);transition:stroke .25s}
.svc-title{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:600;color:var(--blue);margin-bottom:.7rem;transition:color .25s}
.svc-body{font-size:.82rem;line-height:1.7;color:var(--muted);transition:color .25s}

/* PAYROLL */
#payroll{background:var(--blue)}
.payroll-head{max-width:680px;margin-bottom:3.5rem}
.payroll-head .section-title{color:var(--white)}
.payroll-head .section-body{color:rgba(255,255,255,.65);max-width:none}
.payroll-head .eyebrow{color:rgba(255,199,38,.85)}
.payroll-head .eyebrow::before{background:var(--gold)}
.payroll-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.08)}
.payroll-card{background:rgba(255,255,255,.04);padding:2rem 1.8rem;transition:background .25s;position:relative;overflow:hidden}
.payroll-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.payroll-card:hover{background:rgba(255,255,255,.1)}
.payroll-card:hover::before{transform:scaleX(1)}
.payroll-card-icon{width:48px;height:48px;border-radius:50%;background:rgba(255,199,38,.12);display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem}
.payroll-card-icon svg{stroke:var(--gold)}
.payroll-card:hover .payroll-card-icon{background:rgba(255,199,38,.2)}
.payroll-card-title{font-family:'Playfair Display',serif;font-size:1rem;font-weight:600;color:var(--white);margin-bottom:.6rem}
.payroll-card-body{font-size:.8rem;line-height:1.65;color:rgba(255,255,255,.5)}

/* SOFTWARE */
#software{background:var(--off-white)}
.software-inner{display:grid;grid-template-columns:1fr 1fr;gap:6vw;align-items:start;margin-bottom:4rem}
.software-left .section-body{max-width:none;margin-bottom:1.5rem}
.software-highlight{background:var(--blue);border-radius:4px;padding:1.8rem;margin-top:1.5rem;display:flex;flex-direction:column;gap:.8rem}
.sh-item{display:flex;align-items:flex-start;gap:.8rem}
.sh-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:.45rem}
.sh-text{font-size:.86rem;color:rgba(255,255,255,.75);line-height:1.5}
.sh-text strong{color:var(--gold);font-weight:600}
.qb-badge{display:inline-flex;align-items:center;gap:.7rem;background:var(--white);border:1px solid var(--line);padding:.6rem 1rem .6rem .7rem;border-radius:4px;margin-bottom:1.5rem}
.qb-badge-icon{width:32px;height:32px;border-radius:3px;background:#1B7F2A;display:flex;align-items:center;justify-content:center}
.qb-badge-icon svg{stroke:var(--white)}
.qb-badge-text{font-size:.76rem;font-weight:600;color:var(--muted)}
.qb-badge-text strong{display:block;font-size:.82rem;color:var(--blue)}
.sw-services-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}
.sw-card{background:var(--white);padding:1.6rem;transition:background .2s,transform .2s;position:relative;overflow:hidden}
.sw-card::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--gold);transform:scaleY(0);transform-origin:top;transition:transform .25s}
.sw-card:hover{background:var(--blue-light);transform:translateX(4px)}
.sw-card:hover::after{transform:scaleY(1)}
.sw-card-icon{width:38px;height:38px;border-radius:8px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;margin-bottom:.8rem}
.sw-card-icon svg{stroke:var(--blue)}
.sw-card:hover .sw-card-icon{background:var(--blue)}
.sw-card:hover .sw-card-icon svg{stroke:var(--gold)}
.sw-card-title{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700;color:var(--blue);margin-bottom:.4rem}
.sw-card-body{font-size:.79rem;line-height:1.6;color:var(--muted)}

/* TEAM */
#team{background:var(--white)}
.team-head{max-width:600px;margin-bottom:3.5rem}
.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:2rem}
.team-card{background:var(--off-white);border-radius:4px;padding:2rem;overflow:hidden;position:relative;border:1px solid var(--line);transition:box-shadow .25s,transform .25s}
.team-card:hover{box-shadow:0 12px 40px rgba(0,38,127,.1);transform:translateY(-4px)}
.team-top{height:5px;margin:-2rem -2rem 1.5rem;background:linear-gradient(90deg,var(--blue),var(--gold))}
.team-avatar{width:64px;height:64px;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--white);margin-bottom:1rem;border:3px solid var(--gold)}
.team-name{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;color:var(--blue);margin-bottom:.15rem}
.team-cred{font-size:.68rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-dark);font-weight:700;margin-bottom:.2rem}
.team-role{font-size:.8rem;color:var(--muted);margin-bottom:.9rem}
.team-divider{width:32px;height:2px;background:var(--gold);margin-bottom:.9rem}
.team-bio{font-size:.82rem;line-height:1.7;color:var(--muted)}
.associates-card{background:var(--blue);border-radius:4px;padding:2.5rem;display:grid;grid-template-columns:auto 1fr;gap:2rem;align-items:center}
.assoc-icon{width:56px;height:56px;border-radius:50%;background:rgba(255,199,38,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.assoc-icon svg{stroke:var(--gold)}
.assoc-title{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;color:var(--gold);margin-bottom:.4rem}
.assoc-body{font-size:.86rem;line-height:1.7;color:rgba(255,255,255,.65)}

/* WHY US */
#why{background:var(--blue)}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:6vw;align-items:center}
.why-left .section-title{color:var(--white)}
.why-left .section-body{color:rgba(255,255,255,.65);max-width:none}
.why-items{display:flex;flex-direction:column;gap:1.2rem;margin-top:2.5rem}
.why-item{display:flex;gap:1.2rem;align-items:flex-start;padding:1.5rem;background:rgba(255,255,255,.06);border-radius:4px;border-left:3px solid var(--gold);transition:background .2s}
.why-item:hover{background:rgba(255,255,255,.1)}
.why-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700;color:rgba(255,199,38,.3);line-height:1;flex-shrink:0}
.why-text-title{font-weight:600;color:var(--white);font-size:.92rem;margin-bottom:.3rem}
.why-text-body{font-size:.82rem;color:rgba(255,255,255,.55);line-height:1.6}
.why-right{display:flex;flex-direction:column;gap:1rem}
.why-stat-card{background:var(--gold);border-radius:4px;padding:1.8rem 2rem;display:flex;justify-content:space-between;align-items:center}
.why-stat-card.dark{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1)}
.why-stat-num{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:700;color:var(--blue-dark)}
.why-stat-card.dark .why-stat-num{color:var(--gold)}
.why-stat-label{font-size:.78rem;font-weight:600;color:var(--blue);text-transform:uppercase;letter-spacing:.08em}
.why-stat-card.dark .why-stat-label{color:rgba(255,255,255,.5)}
.why-stat-icon{width:48px;height:48px;border-radius:50%;background:rgba(0,38,127,.12);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.why-stat-icon svg{stroke:var(--blue-dark)}
.why-stat-card.dark .why-stat-icon{background:rgba(255,199,38,.12)}
.why-stat-card.dark .why-stat-icon svg{stroke:var(--gold)}

/* BLOG */
#blog{background:var(--off-white)}
.blog-head{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;flex-wrap:wrap;gap:1rem}
.blog-all{font-size:.78rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);text-decoration:none;border-bottom:2px solid var(--gold);padding-bottom:2px;transition:color .2s}
.blog-all:hover{color:var(--gold-dark)}
.blog-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:1.5rem}
.blog-card{background:var(--white);border-radius:4px;overflow:hidden;border:1px solid var(--line);transition:box-shadow .25s,transform .25s}
.blog-card:hover{box-shadow:0 12px 40px rgba(0,38,127,.1);transform:translateY(-4px)}
.blog-img{height:180px;display:flex;align-items:center;justify-content:center;position:relative}
.blog-card.feat .blog-img{height:220px}
.blog-img-icon{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center}
.blog-img-icon svg{stroke:rgba(255,255,255,.8)}
.blog-body{padding:1.6rem}
.blog-tag{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-dark);font-weight:700;margin-bottom:.5rem}
.blog-title{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--blue);line-height:1.3;margin-bottom:.6rem}
.blog-card.feat .blog-title{font-size:1.3rem}
.blog-excerpt{font-size:.81rem;line-height:1.65;color:var(--muted);margin-bottom:.8rem}
.blog-meta{font-size:.72rem;color:rgba(86,96,128,.6)}
.blog-link{display:inline-flex;align-items:center;gap:.4rem;font-size:.76rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--blue);text-decoration:none;margin-top:.8rem;transition:gap .2s}
.blog-link:hover{gap:.8rem}

/* CONTACT */
#contact{background:var(--white);display:grid;grid-template-columns:1fr 1fr;gap:5vw;align-items:start}
.contact-left .section-body{max-width:none}
.contact-details{margin-top:2.5rem;display:flex;flex-direction:column;gap:1.2rem}
.c-item{display:flex;gap:1rem;align-items:flex-start}
.c-icon{width:44px;height:44px;flex-shrink:0;border-radius:50%;background:var(--blue);display:flex;align-items:center;justify-content:center}
.c-icon svg{stroke:var(--gold)}
.c-label{font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold-dark);font-weight:700}
.c-val{font-size:.88rem;color:var(--muted);line-height:1.55;margin-top:.15rem}
.contact-hours{background:var(--blue);border-radius:4px;padding:1.5rem;margin-top:2rem;display:flex;align-items:center;gap:1.2rem}
.contact-hours .c-icon{background:rgba(255,199,38,.2);flex-shrink:0}
.contact-hours .c-icon svg{stroke:var(--gold)}
.hours-text .c-label{color:var(--gold)}
.hours-text .c-val{color:rgba(255,255,255,.7)}
.contact-form{background:var(--off-white);border-radius:4px;padding:2.5rem;border:1px solid var(--line)}
.form-title{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--blue);margin-bottom:.4rem}
.form-sub{font-size:.84rem;color:var(--muted);margin-bottom:2rem}
.fg{margin-bottom:1.2rem}
.fg label{display:block;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);font-weight:600;margin-bottom:.4rem}
.fg input,.fg select,.fg textarea{width:100%;padding:.75rem 1rem;border:1.5px solid var(--line);background:var(--white);font-family:'DM Sans',sans-serif;font-size:.88rem;color:var(--black);border-radius:2px;outline:none;transition:border-color .2s,background .2s}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--blue);background:var(--white)}
.fg textarea{resize:vertical;min-height:110px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.form-btn{width:100%;padding:.9rem;background:var(--blue);color:var(--white);border:none;border-radius:2px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s,transform .15s;margin-top:.5rem}
.form-btn:hover{background:var(--blue-mid);transform:translateY(-1px)}

/* FOOTER */
footer{background:var(--black);padding:5rem 8vw 2rem}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;padding-bottom:3.5rem;border-bottom:1px solid rgba(255,255,255,.08)}
.foot-logo{font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:var(--white);margin-bottom:.3rem}
.foot-logo-sub{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem}
.foot-desc{font-size:.82rem;color:rgba(255,255,255,.35);line-height:1.75;max-width:260px}
.foot-col h4{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.3);font-weight:700;margin-bottom:1.2rem}
.foot-col ul{list-style:none;display:flex;flex-direction:column;gap:.65rem}
.foot-col a{font-size:.82rem;color:rgba(255,255,255,.5);text-decoration:none;transition:color .2s}
.foot-col a:hover{color:var(--gold)}
.footer-bot{padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.foot-copy{font-size:.74rem;color:rgba(255,255,255,.22)}
.foot-gold-line{width:40px;height:3px;background:var(--gold);border-radius:2px}

/* RESPONSIVE */
@media(max-width:960px){
  #hero{grid-template-columns:1fr;padding:5rem 6vw 4rem}
